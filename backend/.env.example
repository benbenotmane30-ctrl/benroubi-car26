# ─── Serveur ─────────────────────────────────────
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
ADMIN_URL=http://localhost:5174

# ─── Base de données PostgreSQL (Supabase) ──────
# Connect to Postgres via the shared transaction-mode pooler (IPv4-only)
DATABASE_URL="postgresql://postgres.PROJECT_REF:[YOUR-PASSWORD]@aws-0-eu-west-3.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Connect to Postgres via the shared session-mode pooler (used for migrations)
DIRECT_URL="postgresql://postgres.PROJECT_REF:[YOUR-PASSWORD]@aws-0-eu-west-3.pooler.supabase.com:5432/postgres"

# ─── Authentification admin ──────────────────────
ADMIN_USER=Youssef
ADMIN_PASS_HASH=changeme-sha256-hash-of-password
SESSION_SECRET=changeme-very-long-random-secret-at-least-64-chars
SESSION_TTL_HOURS=8

# ─── Brevo (email transactionnel) ────────────────
BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDER_EMAIL=your-verified-sender@gmail.com
SENDER_NAME=Benroubi Car
DEST_EMAIL=destination@example.com
