# ═══════════════════════════════════════════
#  Benroubi Car — Variables d'environnement
#  Renommez ce fichier en .env
# ═══════════════════════════════════════════

# Gmail — compte qui ENVOIE les e-mails
# Utilisez un compte Gmail dédié (ex: benroubi.car.send@gmail.com)
GMAIL_USER=votre.email@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# E-mail qui REÇOIT les demandes
DEST_EMAIL=benroubicar@yahoo.fr

# Port du serveur (Render le définit automatiquement)
PORT=3000

# URL de votre site front-end (pour CORS)
# Ex: https://benroubi-car.ma ou * pour tout autoriser
FRONTEND_URL=*
